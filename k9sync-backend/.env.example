# Server
NODE_ENV=development
# Port API (3001 si 3000 déjà utilisé)
PORT=3002
API_PREFIX=v1

# Database (PostgreSQL)
DATABASE_URL=postgresql://k9sync:password@localhost:5432/k9sync_dev

# Redis (blacklist JWT, rate limit)
REDIS_URL=redis://localhost:6379

# MQTT (Mosquitto — collier IoT)
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# JWT
# Generate a real random secret, never reuse this placeholder: openssl rand -hex 32
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

# Firebase Admin SDK (FCM push) — path to JSON key file
GOOGLE_APPLICATION_CREDENTIALS=./config/firebase-adminsdk.json

# Optional: Sentry
SENTRY_DSN=

# Log
LOG_LEVEL=info
