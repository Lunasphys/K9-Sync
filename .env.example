# API Backend
API_BASE_URL=https://api.k9sync.app/v1
API_BASE_URL_DEV=http://localhost:3000/v1
API_TIMEOUT_MS=10000

# Firebase
FIREBASE_PROJECT_ID=k9sync-prod
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_APP_ID=1:123456789:android:abcdef
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_STORAGE_BUCKET=k9sync-prod.appspot.com

# Cartographie
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Sentry (monitoring erreurs)
SENTRY_DSN=https://your_key@sentry.io/project_id

# Feature flags
FEATURE_COMMUNITY_ENABLED=false
FEATURE_VET_RECORDS_ENABLED=false
FEATURE_AI_ANOMALY_ENABLED=false
